// Copy this file to lib/dev_credentials.dart and fill in your dev server.
// dev_credentials.dart is gitignored, so your edits stay local.
//
// When enabled, the AddServer form auto-prefills these values on every
// fresh install. Used in both debug and release builds — strip the import
// in features/onboarding/add_server_screen.dart before shipping production.

import 'core/ssh/ssh_models.dart';

class DevCredentials {
  /// `true` to auto-fill the AddServer form with the values below.
  static const bool enabled = false;

  static const String name = 'dev-server';
  static const String host = '';
  static const int port = 22;
  static const String username = '';
  static const SshAuthMode authMode = SshAuthMode.privateKey;

  /// PEM-encoded private key. The `r'''...'''` is a *raw* triple-quoted
  /// string — Dart does NOT interpret `\n`, `\`, `$`, or any other escape
  /// inside, so you can paste your PEM verbatim.
  static const String privateKey = r'''
''';

  /// Empty string = no passphrase.
  static const String passphrase = '';

  /// Used only when [authMode] is [SshAuthMode.password].
  static const String password = '';
}
